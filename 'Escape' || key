describe('ButtonGrid', () => {
  test('renders all number buttons', () => {
    const mockClick = jest.fn();
    render(<ButtonGrid onButtonClick={mockClick} />);

    for (let i = 0; i <= 9; i++) {
      expect(screen.getByTestId(`btn-${i}`)).toBeInTheDocument();
    }
  });

  test('renders operator buttons', () => {
    const mockClick = jest.fn();
    render(<ButtonGrid onButtonClick={mockClick} />);

    expect(screen.getByTestId('btn-+')).toBeInTheDocument();
    expect(screen.getByTestId('btn--')).toBeInTheDocument();
    expect(screen.getByTestId('btn-*')).toBeInTheDocument();
    expect(screen.getByTestId('btn-/')).toBeInTheDocument();
  });

  test('renders special buttons', () => {
    const mockClick = jest.fn();
    render(<ButtonGrid onButtonClick={mockClick} />);

    expect(screen.getByTestId('btn-clear')).toBeInTheDocument();
    expect(screen.getByTestId('btn-equals')).toBeInTheDocument();
    expect(screen.getByTestId('btn-.')).toBeInTheDocument();
  });

  test('calls onButtonClick with correct value when button is clicked', () => {
    const mockClick = jest.fn();
    render(<ButtonGrid onButtonClick={mockClick} />);

    fireEvent.click(screen.getByTestId('btn-5'));
