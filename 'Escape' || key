import { evaluateExpression, formatResult } from '@/lib/calculator';

describe('evaluateExpression', () => {
  test('simple addition', () => {
    expect(evaluateExpression('2+3')).toBe(5);
  });

  test('simple subtraction', () => {
    expect(evaluateExpression('10-4')).toBe(6);
  });

  test('simple multiplication', () => {
    expect(evaluateExpression('3*4')).toBe(12);
  });

  test('simple division', () => {
    expect(evaluateExpression('12/4')).toBe(3);
  });

  test('operator precedence: multiplication before addition', () => {
    expect(evaluateExpression('2+3*4')).toBe(14);
  });

  test('operator precedence: division before subtraction', () => {
    expect(evaluateExpression('10-6/3')).toBe(8);
  });

  test('parentheses override precedence', () => {
    expect(evaluateExpression('(2+3)*4')).toBe(20);
  });

  test('nested parentheses', () => {
    expect(evaluateExpression('((2+3)*4)+1')).toBe(21);
  });

  test('decimal numbers', () => {
    expect(evaluateExpression('1.5+2.5')).toBe(4);
  });

  test('negative numbers with unary minus', () => {
    expect(evaluateExpression('-5+3')).toBe(-2);
  });

  test('complex expression', () => {
    expect(evaluateExpression('(10+5)*2-8/4')).toBe(28);
  });

  test('division by zero throws', () => {
    expect(() => evaluateExpression('5/0')).toThrow('Division by zero');
  });

  test('invalid characters throw', () => {
    expect(() => evaluateExpression('2+abc')).toThrow('Invalid characters');
  });

  test('empty expression throws', () => {
    expect(() => evaluateExpression('')).toThrow('Empty expression');
  });

  test('mismatched parentheses throw', () => {
    expect(() => evaluateExpression('(2+3')).toThrow('Mismatched parentheses');
  });

  test('single number', () => {
    expect(evaluateExpression('42')).toBe(42);
  });

  test('multiple operations same precedence', () => {
    expect(evaluateExpression('1+2+3+4')).toBe(10);
  });

  test('multiple multiplications', () => {
    expect(evaluateExpression('2*3*4')).toBe(24);
  });

  test('expression with spaces in source (whitespace stripped)', () => {
    expect(evaluateExpression(' 2 + 3 ')).toBe(5);
  });
});

describe('formatResult', () => {
  test('formats integer correctly', () => {
    expect(formatResult(42)).toBe('42');
  });

  test('formats decimal correctly', () => {
    expect(formatResult(3.14)).toBe('3.14');
  });

  test('removes trailing zeros', () => {
    expect(formatResult(2.5)).toBe('2.5');
  });

  test('handles zero', () => {
    expect(formatResult(0)).toBe('0');
  });

  test('handles Infinity', () => {
    expect(formatResult(Infinity)).toBe('Error');
  });

  test('handles negative Infinity', () => {
    expect(formatResult(-Infinity)).toBe('Error');
  });

  test('handles NaN', () => {
    expect(formatResult(NaN)).toBe('Error');
  });

  test('handles negative numbers', () => {
    expect(formatResult(-5)).toBe('-5');
  });

  test('handles very small decimal precision', () => {
    // 0.1 + 0.2 = 0.30000000000000004 in JS
    const result = formatResult(0.1 + 0.2);
    expect(result).toBe('0.3');
  });
});
